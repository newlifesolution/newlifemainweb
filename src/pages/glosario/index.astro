---
import PapiroLayout from '../../layouts/PapiroLayout.astro';
import Breadcrumb from '../../components/navigation/Breadcrumb.astro';
import Divider from '../../components/papiro/Divider.astro';
import Glosario from '../../components/papiro/Glosario.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('glosario');

const roots = all.filter(e => !e.data.parent);

const categories = new Map<string, typeof roots>();
for (const e of roots) {
  const cat = e.data.category;
  if (!categories.has(cat)) categories.set(cat, []);
  categories.get(cat)!.push(e);
}

const orderedCats = [...categories.entries()].sort((a, b) => a[0].localeCompare(b[0], 'es'));
---

<PapiroLayout title="Glosario — Papiro" current="glosario">
  <Breadcrumb items={[
    { label: 'Home', href: '/' },
    { label: 'Glosario' },
  ]} />

  <div class="header">
    <div class="hieroglyphs">𓂀 𓃭 𓁹</div>
    <h1>Glosario</h1>
    <p class="subtitle">Términos subyacentes — atómicos, anidados, desplegables.</p>
  </div>

  <Divider />

  <p class="lead">
    Cada entrada es un concepto que el material del máster <em>usa</em> sin explicar.
    Despliega un término para ver su definición y, si tiene términos hijos, expándelo de nuevo: la jerarquía es recursiva.
  </p>

  {orderedCats.map(([cat, entries]) => (
    <section class="cat-section">
      <h2 class="cat-title">{cat}</h2>
      <Glosario entries={entries} all={all} depth={0} />
    </section>
  ))}

  {all.length === 0 && (
    <div class="empty">
      <p>El glosario está vacío. Añade <code>.mdx</code> a <code>src/content/glosario/</code>.</p>
    </div>
  )}
</PapiroLayout>

<style>
  .header {
    text-align: center;
    margin-bottom: 1rem;
  }

  .hieroglyphs {
    font-family: var(--g-font-symbols);
    font-size: 18px;
    color: var(--g-ink-gold);
    letter-spacing: 10px;
    opacity: 0.4;
    margin-bottom: 0.5rem;
  }

  h1 {
    font-family: var(--g-font-display);
    font-size: clamp(1.2rem, 4vw, 1.8rem);
    font-weight: 900;
    color: var(--g-ink-primary);
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 0.3rem;
  }

  .subtitle {
    font-size: 0.9rem;
    color: var(--g-ink-secondary);
  }

  .lead {
    font-size: 0.9rem;
    color: var(--g-ink-secondary);
    margin: 0 0 1.5rem;
    font-style: italic;
    line-height: 1.7;
  }

  .cat-section {
    margin-bottom: 1.8rem;
  }

  .cat-title {
    font-family: var(--g-font-display);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--g-ink-gold);
    letter-spacing: 3px;
    text-transform: uppercase;
    margin: 0 0 0.6rem;
    padding-bottom: 0.3rem;
    border-bottom: 1px solid var(--g-pentacle-line);
  }

  .empty {
    text-align: center;
    padding: 3rem 1rem;
    color: var(--g-ink-secondary);
    font-style: italic;
  }

  .empty code {
    font-family: var(--g-font-mono);
    font-size: 0.75rem;
    background: rgba(42,31,20,0.08);
    padding: 1px 5px;
    border-radius: 2px;
    font-style: normal;
  }
</style>
