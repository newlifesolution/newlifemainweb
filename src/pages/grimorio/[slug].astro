---
import PapiroLayout from '../../layouts/PapiroLayout.astro';
import Breadcrumb from '../../components/navigation/Breadcrumb.astro';
import Divider from '../../components/papiro/Divider.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('grimorio');
  return entries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<PapiroLayout title={`${entry.data.title} — Grimorio`} current="grimorio">
  <Breadcrumb items={[
    { label: 'Home', href: '/' },
    { label: 'Grimorio', href: '/grimorio' },
    { label: entry.data.module, href: '/grimorio' },
    { label: entry.data.title },
  ]} />

  <article class="papiro-article">
    <header class="article-header">
      <div class="article-meta">
        <span class="module-badge">{entry.data.module}</span>
        <span class="date">{entry.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
      </div>
      <h1>{entry.data.title}</h1>
      {entry.data.progress > 0 && (
        <div class="progress-bar">
          <div class="progress-fill" style={`width: ${entry.data.progress}%`}></div>
          <span class="progress-label">{entry.data.progress}% complete</span>
        </div>
      )}
      {entry.data.tags.length > 0 && (
        <div class="tags">
          {entry.data.tags.map(tag => <span class="tag">{tag}</span>)}
        </div>
      )}
    </header>

    {entry.data.conjuro && (
      <>
        <div class="conjuro-inline">
          <span class="conjuro-sym">🜔</span>
          <span class="conjuro-text">{entry.data.conjuro}</span>
        </div>
      </>
    )}

    <Divider />

    <div class="article-body">
      <Content />
    </div>
  </article>
</PapiroLayout>

<style>
  .papiro-article {
    max-width: 100%;
  }

  .article-header {
    margin-bottom: 1.5rem;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .module-badge {
    font-family: var(--g-font-display);
    font-size: 0.6rem;
    font-weight: 600;
    color: var(--g-ink-gold);
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 0.2rem 0.6rem;
    border: 1px solid var(--g-pentacle-line);
    border-radius: 3px;
  }

  .date {
    font-family: var(--g-font-mono);
    font-size: 0.65rem;
    color: var(--g-ink-secondary);
  }

  h1 {
    font-family: var(--g-font-display);
    font-size: clamp(1.2rem, 4vw, 1.6rem);
    font-weight: 900;
    color: var(--g-ink-primary);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .progress-bar {
    position: relative;
    height: 6px;
    background: rgba(42,31,20,0.1);
    border-radius: 3px;
    margin-bottom: 0.75rem;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--g-ink-gold), var(--g-demon-glow));
    border-radius: 3px;
    transition: width 0.3s;
  }

  .progress-label {
    position: absolute;
    right: 0;
    top: -18px;
    font-family: var(--g-font-mono);
    font-size: 0.6rem;
    color: var(--g-ink-gold);
  }

  .tags {
    display: flex;
    gap: 0.3rem;
    flex-wrap: wrap;
  }

  .tag {
    font-family: var(--g-font-mono);
    font-size: 0.6rem;
    color: var(--g-ink-secondary);
    background: rgba(42,31,20,0.06);
    padding: 2px 8px;
    border-radius: 2px;
  }

  .conjuro-inline {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    padding: 0.8rem 1rem;
    background: var(--g-bg-conjuro);
    border: 1px solid rgba(196,160,80,0.2);
    border-radius: 4px;
    margin-bottom: 1rem;
  }

  .conjuro-sym {
    font-size: 1.1rem;
    color: var(--g-conjuro-border);
    flex-shrink: 0;
  }

  .conjuro-text {
    font-family: var(--g-font-body);
    font-style: italic;
    font-size: 0.9rem;
    color: var(--g-conjuro-text);
    line-height: 1.6;
  }

  /* MDX content styling */
  .article-body :global(h1),
  .article-body :global(h2),
  .article-body :global(h3) {
    font-family: var(--g-font-display);
    color: var(--g-ink-primary);
    letter-spacing: 1px;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .article-body :global(h2) {
    font-size: 1.1rem;
    font-weight: 700;
    text-transform: uppercase;
    padding-bottom: 0.3rem;
    border-bottom: 1px solid var(--g-pentacle-line);
  }

  .article-body :global(h3) {
    font-size: 0.95rem;
    font-weight: 600;
  }

  .article-body :global(p) {
    font-size: 0.95rem;
    color: var(--g-ink-secondary);
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .article-body :global(strong) {
    color: var(--g-ink-primary);
    font-weight: 600;
  }

  .article-body :global(code) {
    font-family: var(--g-font-mono);
    font-size: 0.8rem;
    background: rgba(42,31,20,0.08);
    padding: 1px 5px;
    border-radius: 2px;
  }

  .article-body :global(pre) {
    background: var(--g-bg-conjuro);
    border: 1px solid rgba(196,160,80,0.2);
    border-radius: 4px;
    padding: 1rem;
    overflow-x: auto;
    margin: 1rem 0;
  }

  .article-body :global(pre code) {
    background: none;
    padding: 0;
    font-size: 0.78rem;
    color: var(--g-conjuro-text);
  }

  .article-body :global(ul),
  .article-body :global(ol) {
    margin: 0.5rem 0 1rem 1.5rem;
    color: var(--g-ink-secondary);
    font-size: 0.95rem;
  }

  .article-body :global(li) {
    margin-bottom: 0.3rem;
  }

  .article-body :global(blockquote) {
    border-left: 2px solid var(--g-ink-gold);
    padding: 0.5rem 1rem;
    margin: 1rem 0;
    font-style: italic;
    color: var(--g-ink-secondary);
    background: rgba(139,105,20,0.05);
    border-radius: 0 3px 3px 0;
  }

  .article-body :global(a) {
    color: var(--g-ink-gold);
    text-decoration: underline;
    text-decoration-color: rgba(139,105,20,0.3);
    text-underline-offset: 2px;
  }

  .article-body :global(a:hover) {
    text-decoration-color: var(--g-ink-gold);
  }
</style>
