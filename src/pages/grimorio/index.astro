---
import PapiroLayout from '../../layouts/PapiroLayout.astro';
import Breadcrumb from '../../components/navigation/Breadcrumb.astro';
import Divider from '../../components/papiro/Divider.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('grimorio'))
  .filter(e => !e.data.draft)
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

// Group by module
const modules = new Map<string, typeof entries>();
for (const entry of entries) {
  const mod = entry.data.module;
  if (!modules.has(mod)) modules.set(mod, []);
  modules.get(mod)!.push(entry);
}
---

<PapiroLayout title="Grimorio Académico" current="grimorio">
  <Breadcrumb items={[
    { label: 'Home', href: '/' },
    { label: 'Grimorio' },
  ]} />

  <div class="header">
    <div class="hieroglyphs">𓁹 𓂀 𓆣</div>
    <h1>Grimorio Académico</h1>
    <p class="subtitle">Course modules, notes, and conjuros from the master's.</p>
  </div>

  <Divider />

  {entries.length <= 1 && entries[0]?.slug === 'welcome' ? (
    <div class="empty-state">
      <p>The grimoire awaits its first real entry.</p>
      <p class="hint">Add <code>.mdx</code> files to <code>src/content/grimorio/</code> to begin.</p>
    </div>
  ) : (
    <div class="module-list">
      {[...modules.entries()].map(([moduleName, moduleEntries]) => (
        <div class="module-group">
          <h2 class="module-title">{moduleName}</h2>
          {moduleEntries.map(entry => (
            <a href={`/grimorio/${entry.id}`} class="entry-card">
              <div class="entry-meta">
                <span class="entry-date">{entry.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</span>
                {entry.data.progress > 0 && (
                  <span class="entry-progress">{entry.data.progress}%</span>
                )}
              </div>
              <h3>{entry.data.title}</h3>
              {entry.data.tags.length > 0 && (
                <div class="entry-tags">
                  {entry.data.tags.map(tag => <span class="tag">{tag}</span>)}
                </div>
              )}
            </a>
          ))}
        </div>
      ))}
    </div>
  )}
</PapiroLayout>

<style>
  .header {
    text-align: center;
    margin-bottom: 1rem;
  }

  .hieroglyphs {
    font-family: var(--g-font-symbols);
    font-size: 18px;
    color: var(--g-ink-gold);
    letter-spacing: 10px;
    opacity: 0.4;
    margin-bottom: 0.5rem;
  }

  h1 {
    font-family: var(--g-font-display);
    font-size: clamp(1.2rem, 4vw, 1.8rem);
    font-weight: 900;
    color: var(--g-ink-primary);
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 0.3rem;
  }

  .subtitle {
    font-size: 0.9rem;
    color: var(--g-ink-secondary);
  }

  .empty-state {
    text-align: center;
    padding: 3rem 1rem;
    color: var(--g-ink-secondary);
    font-style: italic;
  }

  .empty-state .hint {
    margin-top: 0.5rem;
    font-size: 0.8rem;
    opacity: 0.6;
    font-style: normal;
  }

  .empty-state code {
    font-family: var(--g-font-mono);
    font-size: 0.75rem;
    background: rgba(42,31,20,0.08);
    padding: 1px 5px;
    border-radius: 2px;
  }

  .module-group {
    margin-bottom: 2rem;
  }

  .module-title {
    font-family: var(--g-font-display);
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--g-ink-gold);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
    padding-bottom: 0.3rem;
    border-bottom: 1px solid var(--g-pentacle-line);
  }

  .entry-card {
    display: block;
    padding: 0.8rem 1rem;
    margin-bottom: 0.5rem;
    border: 1px solid var(--g-pentacle-line);
    border-radius: 4px;
    background: rgba(42,31,20,0.03);
    text-decoration: none;
    transition: all 0.2s;
  }

  .entry-card:hover {
    background: rgba(42,31,20,0.08);
    box-shadow: 0 2px 12px rgba(139,108,66,0.1);
    transform: translateY(-1px);
    opacity: 1;
  }

  .entry-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.3rem;
  }

  .entry-date {
    font-family: var(--g-font-mono);
    font-size: 0.65rem;
    color: var(--g-ink-gold);
    letter-spacing: 0.5px;
  }

  .entry-progress {
    font-family: var(--g-font-mono);
    font-size: 0.6rem;
    color: var(--g-ink-green);
    background: rgba(45,74,34,0.1);
    padding: 1px 6px;
    border-radius: 3px;
  }

  h3 {
    font-family: var(--g-font-body);
    font-size: 1rem;
    font-weight: 600;
    color: var(--g-ink-primary);
    margin-bottom: 0.3rem;
  }

  .entry-tags {
    display: flex;
    gap: 0.3rem;
    flex-wrap: wrap;
  }

  .tag {
    font-family: var(--g-font-mono);
    font-size: 0.6rem;
    color: var(--g-ink-secondary);
    background: rgba(42,31,20,0.06);
    padding: 1px 6px;
    border-radius: 2px;
  }
</style>
