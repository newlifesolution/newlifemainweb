---
import PapiroLayout from '../../layouts/PapiroLayout.astro';
import Breadcrumb from '../../components/navigation/Breadcrumb.astro';
import Divider from '../../components/papiro/Divider.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('proyectos');
  return entries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<PapiroLayout title={`${entry.data.title} — Projects`} current="proyectos">
  <Breadcrumb items={[
    { label: 'Home', href: '/' },
    { label: 'Projects', href: '/proyectos' },
    { label: entry.data.title },
  ]} />

  <article class="project-article">
    <header>
      <div class="meta-row">
        <span class="status-badge">{entry.data.status}</span>
        <span class="date">{entry.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
      </div>
      <h1>{entry.data.title}</h1>
      <p class="description">{entry.data.description}</p>

      <div class="action-row">
        {entry.data.repo && (
          <a href={entry.data.repo} target="_blank" rel="noopener noreferrer" class="action-link">Repository</a>
        )}
        {entry.data.demo && (
          <a href={entry.data.demo} target="_blank" rel="noopener noreferrer" class="action-link demo">Live Demo</a>
        )}
      </div>

      {entry.data.stack.length > 0 && (
        <div class="stack-row">
          {entry.data.stack.map(s => <span class="tech-tag">{s}</span>)}
        </div>
      )}
    </header>

    <Divider />

    <div class="article-body">
      <Content />
    </div>
  </article>
</PapiroLayout>

<style>
  .meta-row {
    display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem;
  }

  .status-badge {
    font-family: var(--g-font-display);
    font-size: 0.6rem; font-weight: 600;
    color: var(--g-ink-gold); letter-spacing: 2px; text-transform: uppercase;
    padding: 0.2rem 0.6rem;
    border: 1px solid var(--g-pentacle-line); border-radius: 3px;
  }

  .date {
    font-family: var(--g-font-mono);
    font-size: 0.65rem; color: var(--g-ink-secondary);
  }

  h1 {
    font-family: var(--g-font-display);
    font-size: clamp(1.2rem, 4vw, 1.6rem);
    font-weight: 900; color: var(--g-ink-primary);
    letter-spacing: 2px; text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .description {
    font-size: 1rem; color: var(--g-ink-secondary); line-height: 1.7; margin-bottom: 1rem;
  }

  .action-row { display: flex; gap: 0.5rem; margin-bottom: 0.75rem; flex-wrap: wrap; }

  .action-link {
    font-family: var(--g-font-mono); font-size: 0.72rem;
    color: var(--g-ink-gold); padding: 0.35rem 0.8rem;
    border: 1px solid var(--g-pentacle-line); border-radius: 3px;
    transition: all 0.2s; text-decoration: none;
  }

  .action-link:hover {
    border-color: var(--g-ink-gold); background: rgba(139,105,20,0.08); opacity: 1;
  }

  .action-link.demo { border-color: var(--g-ink-green); color: var(--g-ink-green); }
  .action-link.demo:hover { background: rgba(45,74,34,0.08); }

  .stack-row { display: flex; gap: 0.3rem; flex-wrap: wrap; margin-bottom: 0.5rem; }

  .tech-tag {
    font-family: var(--g-font-mono); font-size: 0.6rem;
    color: var(--g-conjuro-text); background: var(--g-bg-conjuro);
    padding: 2px 8px; border-radius: 3px;
  }

  /* Reuse grimorio article body styles */
  .article-body :global(h2) {
    font-family: var(--g-font-display); font-size: 1.1rem; font-weight: 700;
    color: var(--g-ink-primary); letter-spacing: 1px; text-transform: uppercase;
    margin-top: 1.5rem; margin-bottom: 0.5rem;
    padding-bottom: 0.3rem; border-bottom: 1px solid var(--g-pentacle-line);
  }

  .article-body :global(p) {
    font-size: 0.95rem; color: var(--g-ink-secondary); line-height: 1.8; margin-bottom: 1rem;
  }

  .article-body :global(strong) { color: var(--g-ink-primary); font-weight: 600; }

  .article-body :global(code) {
    font-family: var(--g-font-mono); font-size: 0.8rem;
    background: rgba(42,31,20,0.08); padding: 1px 5px; border-radius: 2px;
  }

  .article-body :global(pre) {
    background: var(--g-bg-conjuro); border: 1px solid rgba(196,160,80,0.2);
    border-radius: 4px; padding: 1rem; overflow-x: auto; margin: 1rem 0;
  }

  .article-body :global(pre code) {
    background: none; padding: 0; font-size: 0.78rem; color: var(--g-conjuro-text);
  }
</style>
