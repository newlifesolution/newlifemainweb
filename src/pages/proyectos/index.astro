---
import PapiroLayout from '../../layouts/PapiroLayout.astro';
import Breadcrumb from '../../components/navigation/Breadcrumb.astro';
import Divider from '../../components/papiro/Divider.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('proyectos'))
  .filter(e => !e.data.status || e.data.status !== 'planning' || e.data.featured)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const statusIcon: Record<string, string> = {
  planning: '☽',
  active: '☿',
  complete: '☉',
};
---

<PapiroLayout title="Taller de Proyectos" current="proyectos">
  <Breadcrumb items={[
    { label: 'Home', href: '/' },
    { label: 'Projects' },
  ]} />

  <div class="header">
    <div class="hieroglyphs">🜁 🜃 🜔</div>
    <h1>Taller de Proyectos</h1>
    <p class="subtitle">AI/ML projects, experiments, and case studies.</p>
  </div>

  <Divider />

  {entries.length === 0 || (entries.length === 1 && entries[0]?.slug === 'first-project') ? (
    <div class="empty-state">
      <p>The workshop awaits its first project.</p>
      <p class="hint">Add <code>.mdx</code> files to <code>src/content/proyectos/</code> to begin.</p>
    </div>
  ) : (
    <div class="project-grid">
      {entries.map(entry => (
        <a href={`/proyectos/${entry.id}`} class="project-card">
          <div class="project-meta">
            <span class="status">{statusIcon[entry.data.status] || '☽'} {entry.data.status}</span>
            <span class="date">{entry.data.date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}</span>
          </div>
          <h3>{entry.data.title}</h3>
          <p class="desc">{entry.data.description}</p>
          {entry.data.stack.length > 0 && (
            <div class="stack-tags">
              {entry.data.stack.map(s => <span class="tech-tag">{s}</span>)}
            </div>
          )}
        </a>
      ))}
    </div>
  )}
</PapiroLayout>

<style>
  .header { text-align: center; margin-bottom: 1rem; }

  .hieroglyphs {
    font-size: 18px;
    color: var(--g-ink-gold);
    letter-spacing: 10px;
    opacity: 0.4;
    margin-bottom: 0.5rem;
  }

  h1 {
    font-family: var(--g-font-display);
    font-size: clamp(1.2rem, 4vw, 1.8rem);
    font-weight: 900;
    color: var(--g-ink-primary);
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 0.3rem;
  }

  .subtitle { font-size: 0.9rem; color: var(--g-ink-secondary); }

  .empty-state {
    text-align: center; padding: 3rem 1rem;
    color: var(--g-ink-secondary); font-style: italic;
  }
  .empty-state .hint { margin-top: 0.5rem; font-size: 0.8rem; opacity: 0.6; font-style: normal; }
  .empty-state code {
    font-family: var(--g-font-mono); font-size: 0.75rem;
    background: rgba(42,31,20,0.08); padding: 1px 5px; border-radius: 2px;
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1rem;
  }

  .project-card {
    display: block;
    padding: 1rem 1.2rem;
    border: 1px solid var(--g-pentacle-line);
    border-radius: 4px;
    background: rgba(42,31,20,0.03);
    text-decoration: none;
    transition: all 0.2s;
  }

  .project-card:hover {
    background: rgba(42,31,20,0.08);
    box-shadow: 0 4px 16px rgba(139,108,66,0.12);
    transform: translateY(-2px);
    opacity: 1;
  }

  .project-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
  }

  .status {
    font-family: var(--g-font-mono);
    font-size: 0.6rem;
    color: var(--g-ink-gold);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .date {
    font-family: var(--g-font-mono);
    font-size: 0.6rem;
    color: var(--g-ink-secondary);
  }

  h3 {
    font-family: var(--g-font-display);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--g-ink-primary);
    letter-spacing: 1px;
    margin-bottom: 0.3rem;
  }

  .desc {
    font-size: 0.85rem;
    color: var(--g-ink-secondary);
    line-height: 1.5;
    margin-bottom: 0.5rem;
  }

  .stack-tags { display: flex; gap: 0.3rem; flex-wrap: wrap; }

  .tech-tag {
    font-family: var(--g-font-mono);
    font-size: 0.6rem;
    color: var(--g-conjuro-text);
    background: var(--g-bg-conjuro);
    padding: 2px 8px;
    border-radius: 3px;
  }
</style>
