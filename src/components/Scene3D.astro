---
// 3D animated "blueprint" background: wireframe technical parts + a faint grid +
// floating CAD callouts (Ø50, R5, ±0.1…). Sits fixed behind the page content.
// Respects prefers-reduced-motion (renders one static frame, no loop) and pauses
// when the tab is hidden. All resources disposed on teardown.
---
<canvas id="bg3d" aria-hidden="true"></canvas>

<script>
  import * as THREE from 'three';

  const canvas = document.getElementById('bg3d') as HTMLCanvasElement | null;
  if (canvas) {
    const ACCENT = 0x00e0c6;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const scene = new THREE.Scene();
    scene.fog = new THREE.FogExp2(0x0a0b0f, 0.045);

    const camera = new THREE.PerspectiveCamera(55, window.innerWidth / window.innerHeight, 0.1, 100);
    camera.position.set(0, 1.5, 11);

    const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setSize(window.innerWidth, window.innerHeight);

    const root = new THREE.Group();
    scene.add(root);

    // --- faint blueprint grid ---
    const grid = new THREE.GridHelper(40, 40, ACCENT, ACCENT);
    (grid.material as THREE.Material).opacity = 0.08;
    (grid.material as THREE.Material).transparent = true;
    grid.position.y = -4;
    root.add(grid);

    // --- wireframe technical parts ---
    const lineMat = new THREE.LineBasicMaterial({ color: ACCENT, transparent: true, opacity: 0.55 });
    const dimMat = new THREE.LineBasicMaterial({ color: 0x6f7b8a, transparent: true, opacity: 0.4 });

    function wire(geo: THREE.BufferGeometry, x: number, y: number, z: number, s = 1) {
      const edges = new THREE.LineSegments(new THREE.EdgesGeometry(geo), lineMat);
      edges.position.set(x, y, z);
      edges.scale.setScalar(s);
      edges.userData.spin = (Math.random() - 0.5) * 0.0045;
      edges.userData.spin2 = (Math.random() - 0.5) * 0.003;
      root.add(edges);
      geo.dispose();
      return edges;
    }
    const parts: THREE.LineSegments[] = [
      wire(new THREE.BoxGeometry(2.4, 2.4, 2.4), -4.5, 0.5, -1, 1),
      wire(new THREE.CylinderGeometry(1.3, 1.3, 2.6, 20), 4.2, -0.5, -2, 1),
      wire(new THREE.TorusGeometry(1.3, 0.45, 10, 28), 2, 2.4, -4, 1),
      wire(new THREE.ConeGeometry(1.3, 2.4, 18), -2.5, -2.2, -3, 0.9),
      wire(new THREE.IcosahedronGeometry(1.4, 0), 0.5, 0.2, 1, 1),
      wire(new THREE.TorusKnotGeometry(0.9, 0.3, 64, 8), 6, 2.2, -6, 0.8),
    ];

    // --- dimension lines (a couple of "measured" segments) ---
    function dimLine(pts: number[][]) {
      const g = new THREE.BufferGeometry().setFromPoints(pts.map((p) => new THREE.Vector3(p[0], p[1], p[2])));
      root.add(new THREE.Line(g, dimMat));
    }
    dimLine([[-4.5, 2.1, -1], [-4.5, 3, -1], [-1.7, 3, -1], [-1.7, 2.1, -1]]);
    dimLine([[4.2, -2.1, -2], [4.2, -3, -2], [2.2, -3, -2]]);

    // --- floating CAD callouts (the "moving text") ---
    const labels = ['Ø50', 'R5', '±0.1', '45°', 'A-A', '1:2', 'M8', 'Ra 3.2', '⌀20 H7', '120°', 'TYP', '2x45°'];
    function makeLabel(text: string) {
      const c = document.createElement('canvas');
      c.width = 256; c.height = 96;
      const ctx = c.getContext('2d')!;
      ctx.font = '600 46px ui-monospace, "JetBrains Mono", monospace';
      ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
      ctx.fillStyle = 'rgba(0,224,198,0.92)';
      ctx.fillText(text, 128, 50);
      const tex = new THREE.CanvasTexture(c);
      tex.minFilter = THREE.LinearFilter;
      const mat = new THREE.SpriteMaterial({ map: tex, transparent: true, opacity: 0.85, depthWrite: false });
      const sp = new THREE.Sprite(mat);
      sp.scale.set(1.7, 0.64, 1);
      return sp;
    }
    const sprites: THREE.Sprite[] = [];
    labels.forEach((txt) => {
      const sp = makeLabel(txt);
      sp.position.set((Math.random() - 0.5) * 16, (Math.random() - 0.5) * 9, (Math.random() - 0.5) * 6 - 1);
      sp.userData.vy = 0.004 + Math.random() * 0.006;
      sp.userData.phase = Math.random() * Math.PI * 2;
      scene.add(sp);
      sprites.push(sp);
    });

    // --- interaction (subtle parallax) ---
    const mouse = { x: 0, y: 0 };
    const onMove = (e: PointerEvent) => {
      mouse.x = (e.clientX / window.innerWidth - 0.5) * 2;
      mouse.y = (e.clientY / window.innerHeight - 0.5) * 2;
    };
    window.addEventListener('pointermove', onMove, { passive: true });

    function resize() {
      camera.aspect = window.innerWidth / window.innerHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(window.innerWidth, window.innerHeight);
    }
    window.addEventListener('resize', resize);

    let raf = 0;
    let running = true;
    const clock = new THREE.Clock();
    function frame() {
      const t = clock.getElapsedTime();
      root.rotation.y = t * 0.04;
      parts.forEach((p) => { p.rotation.x += p.userData.spin; p.rotation.y += p.userData.spin2; });
      sprites.forEach((sp) => {
        sp.position.y += sp.userData.vy;
        sp.position.x += Math.sin(t * 0.5 + sp.userData.phase) * 0.002;
        if (sp.position.y > 5.5) sp.position.y = -5.5;
      });
      camera.position.x += (mouse.x * 1.2 - camera.position.x) * 0.04;
      camera.position.y += (1.5 - mouse.y * 0.8 - camera.position.y) * 0.04;
      camera.lookAt(0, 0, 0);
      renderer.render(scene, camera);
      if (running) raf = requestAnimationFrame(frame);
    }

    if (reduce) {
      renderer.render(scene, camera); // single static frame
    } else {
      frame();
      document.addEventListener('visibilitychange', () => {
        running = !document.hidden;
        if (running) { clock.start(); frame(); } else cancelAnimationFrame(raf);
      });
    }
  }
</script>

<style>
  #bg3d {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    display: block;
  }
</style>
