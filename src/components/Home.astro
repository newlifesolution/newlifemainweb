---
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
const other = lang === 'es' ? { href: '/en/', label: 'EN' } : { href: '/', label: 'ES' };
const year = 2026;
const contact = 'mailto:hola@newlifesolutions.dev';
const cadlinguaApp = 'https://cadlingua.newlifesolutions.dev';
const feats = [
  { k: 'flag.f1', icon: 'M3 17 L9 11 L13 15 L21 7 M21 7 L21 12 M21 7 L16 7' }, // dimension/measure
  { k: 'flag.f2', icon: 'M4 5 H20 V19 H4 Z M4 9 H20 M8 5 V9' },                  // file/format
  { k: 'flag.f3', icon: 'M12 3 A9 9 0 1 0 12 21 A9 9 0 1 0 12 3 M3 12 H21 M12 3 C8 7 8 17 12 21 C16 17 16 7 12 3' }, // globe
  { k: 'flag.f4', icon: 'M12 3 L20 7 V13 C20 17 16 20 12 21 C8 20 4 17 4 13 V7 Z M9 12 L11 14 L15 10' }, // shield/config
];
---
<header class="nav">
  <div class="wrap nav-inner">
    <a href={lang === 'es' ? '/' : '/en/'} class="brand"><span class="dot"></span>newlife<span class="accent">.</span></a>
    <nav class="nav-links">
      <a href="#cadlingua" class="nav-a">{t('nav.flagship')}</a>
      <a href={cadlinguaApp} target="_blank" rel="noopener" class="btn btn-ghost btn-sm">{t('nav.cta')}</a>
      <a href={other.href} class="lang mono" aria-label={`Switch to ${other.label}`}>{other.label}</a>
    </nav>
  </div>
</header>

<main>
  <!-- HERO -->
  <section class="hero">
    <div class="wrap hero-grid">
      <div class="hero-main" data-reveal>
        <p class="eyebrow">{t('hero.eyebrow')}</p>
        <h1 set:html={t('hero.h1').replace(/(verdad|problems)/i, '<span class="hl">$1</span>')}></h1>
        <p class="hero-sub">{t('hero.sub')}</p>
        <div class="hero-cta">
          <a href="#cadlingua" class="btn btn-primary">{t('hero.cta1')} →</a>
          <a href={contact} class="btn btn-ghost">{t('hero.cta2')}</a>
        </div>
      </div>
      <aside class="hero-spec mono" data-reveal aria-hidden="true">
        <div class="spec-row"><span>STUDIO</span><span class="accent">newlife</span></div>
        <div class="spec-row"><span>STATUS</span><span>● ACTIVE</span></div>
        <div class="spec-row"><span>TOOLS</span><span>01 / ∞</span></div>
        <div class="spec-row"><span>FLAGSHIP</span><span class="accent">CADlingua</span></div>
        <div class="spec-sep"></div>
        <div class="spec-tick">▚ 43.26°N · 2.93°W · BILBAO</div>
      </aside>
    </div>
    <div class="scroll-hint mono">SCROLL ↓</div>
  </section>

  <!-- FLAGSHIP: CADlingua -->
  <section id="cadlingua" class="flagship">
    <div class="wrap">
      <div class="flag-head" data-reveal>
        <span class="flag-badge mono"><span class="sec-n">01</span>{t('flag.badge')}</span>
        <h2 class="flag-name">{t('flag.name')}</h2>
        <p class="flag-tagline">{t('flag.tagline')}</p>
        <p class="flag-body">{t('flag.body')}</p>
        <div class="hero-cta">
          <a href={cadlinguaApp} target="_blank" rel="noopener" class="btn btn-primary">{t('flag.cta')} →</a>
          <span class="soon mono"><span class="pulse"></span>{t('flag.soon')}</span>
        </div>
      </div>
      <div class="flag-features">
        {feats.map((f, i) => (
          <div class="feat" data-reveal style={`transition-delay:${i * 80}ms`}>
            <div class="feat-top">
              <svg viewBox="0 0 24 24" class="feat-icon" aria-hidden="true" focusable="false" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d={f.icon} /></svg>
              <span class="feat-idx mono">0{i + 1}</span>
            </div>
            <h3>{t(`${f.k}.t` as any)}</h3>
            <p>{t(`${f.k}.d` as any)}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- MORE COMING -->
  <section class="more">
    <div class="wrap more-inner" data-reveal>
      <div class="more-slots" aria-hidden="true">
        <span class="slot live mono">CADlingua</span>
        <span class="slot mono">+</span>
        <span class="slot mono">+</span>
      </div>
      <div class="more-copy">
        <p class="eyebrow"><span class="sec-n">02</span>{t('more.eyebrow')}</p>
        <h2>{t('more.title')}</h2>
        <p>{t('more.body')}</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta">
    <div class="wrap cta-inner" data-reveal>
      <p class="eyebrow cta-eyebrow"><span class="sec-n">03</span>{t('cta.eyebrow')}</p>
      <h2>{t('cta.title')}</h2>
      <p>{t('cta.body')}</p>
      <a href={contact} class="btn btn-primary">{t('cta.button')} →</a>
    </div>
  </section>
</main>

<footer class="footer">
  <div class="wrap footer-inner">
    <div class="foot-left">
      <span class="brand"><span class="dot"></span>newlife<span class="accent">.</span></span>
      <span class="ftag">{t('footer.tagline')}</span>
    </div>
    <nav class="footer-links mono">
      <a href={cadlinguaApp} target="_blank" rel="noopener">CADlingua</a>
      <a href={contact}>hola@newlifesolutions.dev</a>
    </nav>
    <span class="mono fcopy">© {year} newlife · {t('footer.rights')}</span>
  </div>
</footer>

<style>
  .nav { position: sticky; top: 0; z-index: 50; backdrop-filter: blur(12px) saturate(140%);
    background: linear-gradient(180deg, rgba(7,8,12,0.9), rgba(7,8,12,0.55)); border-bottom: 1px solid var(--line); }
  .nav-inner { display: flex; align-items: center; justify-content: space-between; height: 66px; }
  .brand { font-family: var(--display); font-size: 1.3rem; font-weight: 700; letter-spacing: -0.03em;
    display: inline-flex; align-items: center; gap: 9px; }
  .brand .dot { width: 9px; height: 9px; border-radius: 50%; background: var(--accent);
    box-shadow: 0 0 12px var(--accent); animation: breathe 3s ease-in-out infinite; }
  @keyframes breathe { 50% { opacity: 0.4; transform: scale(0.82); } }
  .nav-links { display: flex; align-items: center; gap: 22px; }
  .nav-a { font-size: 0.92rem; color: var(--ink-dim); transition: color 0.15s; }
  .nav-a:hover { color: var(--accent); }
  .btn-sm { padding: 9px 17px; font-size: 0.85rem; }
  .lang { font-size: 0.78rem; color: var(--ink-dim); border: 1px solid var(--line-strong);
    border-radius: 8px; padding: 5px 10px; transition: color .15s, border-color .15s; }
  .lang:hover { color: var(--accent); border-color: var(--accent); }

  /* HERO */
  .hero { position: relative; padding-top: 120px; padding-bottom: 120px; }
  .hero-grid { display: grid; grid-template-columns: 1fr 290px; gap: 54px; align-items: center; }
  .hero h1 { font-size: clamp(2.6rem, 7vw, 5rem); margin: 22px 0 24px; max-width: 15ch; }
  .hero h1 :global(.hl) { color: var(--accent); position: relative; white-space: nowrap; }
  .hero-sub { font-size: clamp(1.05rem, 1.7vw, 1.28rem); color: var(--ink-dim); max-width: 50ch; }
  .hero-cta { display: flex; flex-wrap: wrap; gap: 14px; align-items: center; margin-top: 36px; }

  .hero-spec { background: var(--panel); border: 1px solid var(--line);
    border-radius: var(--radius); padding: 22px; backdrop-filter: blur(8px);
    box-shadow: var(--shadow); font-size: 0.78rem; }
  .spec-row { display: flex; justify-content: space-between; padding: 9px 0; color: var(--ink-dim);
    border-bottom: 1px solid var(--line); }
  .spec-row span:first-child { color: var(--ink-faint); letter-spacing: 0.1em; }
  .spec-row span:last-child { color: var(--ink); }
  .spec-sep { height: 14px; }
  .spec-tick { color: var(--accent); font-size: 0.7rem; letter-spacing: 0.12em; opacity: 0.8; }

  .scroll-hint { position: absolute; bottom: 30px; left: 50%; transform: translateX(-50%);
    color: var(--ink-faint); font-size: 0.7rem; letter-spacing: 0.3em;
    animation: floaty 2.4s ease-in-out infinite; }
  @keyframes floaty { 50% { transform: translate(-50%, 7px); } }

  /* FLAGSHIP */
  .flagship { position: relative; background:
    radial-gradient(120% 100% at 100% 0%, rgba(0,230,203,0.06), transparent 55%), var(--bg-soft);
    border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
  .flag-head { max-width: 60ch; margin-bottom: 50px; }
  .flag-badge { display: inline-block; font-size: 0.7rem; letter-spacing: 0.2em;
    text-transform: uppercase; color: var(--accent); background: var(--accent-soft);
    padding: 6px 13px; border-radius: 999px; border: 1px solid rgba(0,230,203,0.25); }
  .flag-name { font-size: clamp(2.4rem, 5.5vw, 3.6rem); margin: 18px 0 10px; }
  .flag-tagline { font-size: clamp(1.15rem, 2vw, 1.45rem); color: var(--ink); font-weight: 500;
    font-family: var(--display); margin-bottom: 16px; }
  .flag-body { color: var(--ink-dim); }
  .soon { font-size: 0.78rem; color: var(--accent); letter-spacing: 0.05em; display: inline-flex;
    align-items: center; gap: 8px; }
  .pulse { width: 8px; height: 8px; border-radius: 50%; background: var(--accent);
    box-shadow: 0 0 0 0 rgba(0,230,203,0.6); animation: pulse 1.8s infinite; }
  @keyframes pulse { 70% { box-shadow: 0 0 0 9px rgba(0,230,203,0); } 100% { box-shadow: 0 0 0 0 rgba(0,230,203,0); } }

  .flag-features { display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; }
  .feat { background: var(--panel); border: 1px solid var(--line); border-radius: var(--radius);
    padding: 24px 22px; backdrop-filter: blur(6px); transition: border-color .2s, transform .2s, box-shadow .2s; }
  .feat:hover { border-color: rgba(0,230,203,0.5); transform: translateY(-5px); box-shadow: var(--glow); }
  .feat-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
  .feat-icon { width: 30px; height: 30px; color: var(--accent); }
  .feat-idx { font-size: 0.72rem; color: var(--ink-faint); }
  .feat h3 { font-size: 1.06rem; margin-bottom: 7px; letter-spacing: -0.01em; }
  .feat p { font-size: 0.9rem; color: var(--ink-dim); line-height: 1.55; }

  /* MORE */
  .more { background: var(--bg); }
  .more-inner { display: flex; align-items: center; gap: 40px; flex-wrap: wrap; }
  .more-slots { display: flex; gap: 14px; }
  .slot { width: 92px; height: 92px; flex: none; border-radius: var(--radius-sm);
    border: 1px dashed var(--line-strong); display: grid; place-items: center; color: var(--ink-faint);
    font-size: 1.6rem; }
  .slot.live { border: 1px solid rgba(0,230,203,0.5); color: var(--accent); font-size: 0.72rem;
    text-align: center; letter-spacing: 0.05em; box-shadow: var(--glow); }
  .more-copy h2 { font-size: clamp(1.5rem, 3vw, 2rem); margin-bottom: 8px; }
  .more-copy p { color: var(--ink-dim); max-width: 46ch; }

  /* CTA */
  .cta { text-align: center; background:
    radial-gradient(80% 140% at 50% 0%, rgba(0,230,203,0.07), transparent 60%), var(--bg); }
  .cta-inner h2 { font-size: clamp(1.8rem, 4vw, 2.8rem); max-width: 22ch; margin: 0 auto 14px; }
  .cta-inner p { color: var(--ink-dim); max-width: 50ch; margin: 0 auto 30px; }

  /* FOOTER */
  .footer { border-top: 1px solid var(--line); padding: 38px 0; background: var(--bg); }
  .footer-inner { display: flex; flex-wrap: wrap; gap: 12px 28px; align-items: center;
    justify-content: space-between; }
  .footer .brand { font-size: 1.1rem; }
  .ftag { color: var(--ink-dim); font-size: 0.9rem; }
  .fcopy { color: var(--ink-faint); font-size: 0.76rem; }

  /* v0.9 cohesion: section index + consistent eyebrows + richer footer */
  .sec-n { font-family: var(--mono); color: var(--accent); }
  .flag-badge .sec-n { margin-right: 8px; opacity: 0.7; }
  .more-copy .eyebrow { margin-bottom: 14px; }
  .cta-eyebrow { margin-bottom: 16px; }
  .cta-eyebrow::before { display: none; }       /* no leading rule when centered */
  .foot-left { display: flex; align-items: baseline; gap: 16px; flex-wrap: wrap; }
  .footer-links { display: flex; gap: 22px; font-size: 0.82rem; }
  .footer-links a { color: var(--ink-dim); transition: color 0.15s; }
  .footer-links a:hover { color: var(--accent); }

  @media (max-width: 860px) {
    .hero-grid { grid-template-columns: 1fr; gap: 34px; }
    .hero-spec { max-width: 340px; }
    .flag-features { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 520px) {
    .flag-features { grid-template-columns: 1fr; }
    .nav-a { display: none; }
    .scroll-hint { display: none; }
  }
</style>
