---
// CRT-TV intro → hyperspace jump → site.
// 1) Old cathode-ray TV with static/interference (the "old solutions" era).
// 2) On click/tap/swipe: CRT power-off collapse to a point.
// 3) Hyperspace tunnel (Star-Wars-style star streaks) while "old solutions" flies away
//    and "newlifesolutions" rushes in.
// 4) White flash → reveal the site.
// Once per session. Skipped for prefers-reduced-motion. Safety auto-enter after 9s.
import type { Lang } from '../i18n/ui';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const prompt = lang === 'es' ? 'CLICK O DESLIZA PARA ENTRAR' : 'CLICK OR SWIPE TO ENTER';
const signal = lang === 'es' ? 'SEÑAL ENTRANTE' : 'INCOMING SIGNAL';
---
<div id="intro" class="intro" role="button" tabindex="0" aria-label={prompt}>
  <div class="crt-screen">
    <canvas id="crt-noise"></canvas>
    <div class="crt-content">
      <div class="crt-sig mono">▚ {signal}</div>
      <div class="crt-brand mono">old solutions<span class="cur">_</span></div>
      <div class="crt-prompt mono">{prompt}</div>
    </div>
    <div class="crt-bar" aria-hidden="true"></div>
  </div>
  <div class="crt-line" aria-hidden="true"></div>
  <div class="crt-dot" aria-hidden="true"></div>
  <canvas id="warp" class="warp" aria-hidden="true"></canvas>
  <div class="warp-text" aria-hidden="true">
    <span class="t-old mono">old solutions</span>
    <span class="t-new mono">newlife<span class="accent">solutions</span></span>
  </div>
  <div class="crt-flash" aria-hidden="true"></div>
</div>

<script>
  const intro = document.getElementById('intro');
  if (intro) {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const seen = sessionStorage.getItem('nl_intro_seen');
    if (reduce || seen) {
      intro.remove();
    } else {
      document.documentElement.style.overflow = 'hidden';
      const noiseC = document.getElementById('crt-noise') as HTMLCanvasElement;
      const nctx = noiseC.getContext('2d')!;
      noiseC.width = 240; noiseC.height = 135;
      const drawNoise = () => {
        const img = nctx.createImageData(noiseC.width, noiseC.height);
        const d = img.data;
        for (let i = 0; i < d.length; i += 4) {
          const v = (Math.random() * 255) | 0;
          d[i] = d[i + 1] = d[i + 2] = v; d[i + 3] = 255;
        }
        nctx.putImageData(img, 0, 0);
      };
      const noiseId = window.setInterval(drawNoise, 38);
      drawNoise();

      // --- hyperspace tunnel ---
      const warp = document.getElementById('warp') as HTMLCanvasElement;
      const wctx = warp.getContext('2d')!;
      let W = 0, H = 0, CX = 0, CY = 0;
      const sizeWarp = () => { W = warp.width = window.innerWidth; H = warp.height = window.innerHeight; CX = W / 2; CY = H / 2; };
      sizeWarp();
      window.addEventListener('resize', sizeWarp);
      const N = 700;
      // angle = fixed radial direction (true vanishing-point tunnel); r grows from center out.
      const mk = (seed = false) => {
        const ang = Math.random() * Math.PI * 2;
        return {
          ang,
          r: seed ? Math.random() * 0.6 : 0.0,          // normalized radius 0..1+
          rr: 0,                                          // previous radius (for streak length)
          spd: 0.55 + Math.random() * 0.9,               // per-star speed multiplier
          hue: Math.random(),                            // 0=teal/white core, ->1 cooler blue
          tw: 0.5 + Math.random() * 0.5,                 // brightness
        };
      };
      const stars = Array.from({ length: N }, () => mk(true));

      function hyperspace(duration: number, onDone: () => void) {
        const start = performance.now();
        const maxR = Math.hypot(W, H) * 0.78; // longer tunnel = deeper, farther vanishing point
        const WARM = 0.42;                      // first 42% = "engine loading" build-up
        const step = (now: number) => {
          const t = Math.min(1, (now - start) / duration);

          // two-phase velocity: gentle load, then a hard jump to full effect.
          let accel, phase; // phase 0..1 within whichever stage (for visuals)
          if (t < WARM) {
            const u = t / WARM;            // 0..1 during load
            accel = 0.0016 + u * u * 0.011; // slow, building
            phase = u * 0.35;
          } else {
            const u = (t - WARM) / (1 - WARM); // 0..1 during full effect
            accel = 0.012 + Math.pow(u, 2.3) * 0.135; // brutal punch
            phase = 0.35 + u * 0.65;
          }

          // motion-blur trail (lighter during load so the tunnel "draws in" slowly)
          wctx.fillStyle = t < WARM ? 'rgba(4,5,9,0.22)' : 'rgba(4,5,9,0.34)';
          wctx.fillRect(0, 0, W, H);

          // --- distant luminous vanishing point: small/deep at first, blooms on the jump ---
          const coreR = (10 + phase * 300) * (1 + 0.1 * Math.sin(now * 0.02));
          const g = wctx.createRadialGradient(CX, CY, 0, CX, CY, coreR);
          g.addColorStop(0, `rgba(220,255,250,${0.35 + phase * 0.6})`);
          g.addColorStop(0.25, `rgba(0,224,198,${0.22 + phase * 0.45})`);
          g.addColorStop(0.6, `rgba(40,120,200,${0.08 + phase * 0.22})`);
          g.addColorStop(1, 'rgba(10,20,40,0)');
          wctx.globalCompositeOperation = 'lighter';
          wctx.fillStyle = g;
          wctx.beginPath(); wctx.arc(CX, CY, coreR, 0, Math.PI * 2); wctx.fill();

          // --- star streaks radiating from the deep core ---
          for (const s of stars) {
            s.rr = s.r;
            s.r += accel * s.spd * (0.12 + s.r * 2.9); // slow near center, rip toward the rim
            if (s.r > 1.2) Object.assign(s, mk(false));
            const cos = Math.cos(s.ang), sin = Math.sin(s.ang);
            const px = CX + cos * s.rr * maxR, py = CY + sin * s.rr * maxR;
            const sx = CX + cos * s.r * maxR, sy = CY + sin * s.r * maxR;
            const a = Math.min(1, s.r * 1.25) * s.tw;
            const rC = 150 + (1 - s.hue) * 105 | 0;
            const gC = 240;
            const bC = 220 + s.hue * 35 | 0;
            wctx.strokeStyle = `rgba(${rC},${gC},${bC},${a})`;
            wctx.lineWidth = Math.max(0.5, s.r * (t < WARM ? 2.2 : 3.4));
            wctx.beginPath(); wctx.moveTo(px, py); wctx.lineTo(sx, sy); wctx.stroke();
          }
          wctx.globalCompositeOperation = 'source-over';

          if (t < 1) requestAnimationFrame(step); else onDone();
        };
        requestAnimationFrame(step);
      }

      let entered = false;
      const onEnter = () => enter();
      const onKey = (e) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); enter(); } };
      const onTouch = () => enter();            // a TAP dismisses on mobile — reliable, no swipe threshold
      const cleanup = () => {
        // Single-fire: detach every trigger so the intro can NEVER re-arm or "reappear".
        intro.removeEventListener('pointerdown', onEnter);
        intro.removeEventListener('keydown', onKey);
        intro.removeEventListener('touchstart', onTouch);
        window.clearTimeout(safety);
      };
      const enter = () => {
        if (entered) return;
        entered = true;
        cleanup();
        window.clearInterval(noiseId);
        sessionStorage.setItem('nl_intro_seen', '1');
        intro.classList.add('off'); // CRT collapse to a bright dot
        // Start the tunnel WHILE the dot is still blooming → one continuous motion,
        // no black gap (which read as "it went away then came back").
        window.setTimeout(() => {
          intro.classList.add('warping');
          hyperspace(1300, () => {
            intro.classList.add('arrive'); // white flash "BAM"
            window.setTimeout(() => {
              document.documentElement.style.overflow = '';
              intro.remove();
              document.dispatchEvent(new Event('intro:done'));
            }, 220);
          });
        }, 470);
      };

      intro.addEventListener('pointerdown', onEnter);
      intro.addEventListener('keydown', onKey);
      intro.addEventListener('touchstart', onTouch, { passive: true });
      intro.focus();
      const safety = window.setTimeout(enter, 7000);
    }
  }
</script>

<style>
  .intro { position: fixed; inset: 0; z-index: 9999; background: #050507; cursor: pointer;
    overflow: hidden; display: grid; place-items: center; }
  .crt-screen { position: absolute; inset: 0; transform-origin: center center;
    animation: flicker 0.13s steps(2) infinite; box-shadow: inset 0 0 160px rgba(0,0,0,0.9); }
  #crt-noise { position: absolute; inset: 0; width: 100%; height: 100%; image-rendering: pixelated; opacity: 0.28; }
  .crt-screen::after { content: ''; position: absolute; inset: 0; pointer-events: none;
    background: repeating-linear-gradient(0deg, rgba(0,0,0,0) 0, rgba(0,0,0,0) 2px, rgba(0,0,0,0.45) 3px);
    mix-blend-mode: multiply; }
  .crt-screen::before { content: ''; position: absolute; inset: 0; pointer-events: none; z-index: 3;
    background: radial-gradient(ellipse 100% 100% at 50% 50%, transparent 52%, rgba(0,0,0,0.9) 100%); }
  .crt-content { position: absolute; inset: 0; z-index: 2; display: flex; flex-direction: column;
    align-items: center; justify-content: center; gap: 18px; text-align: center; padding: 24px; }
  .crt-sig { color: #00e0c6; font-size: 0.78rem; letter-spacing: 0.4em; opacity: 0.7; animation: blink 1.1s steps(2) infinite; }
  .crt-brand { font-size: clamp(2rem, 9vw, 5rem); font-weight: 700; letter-spacing: -0.01em; color: #eef0f4;
    text-shadow: 2px 0 rgba(255,0,80,0.7), -2px 0 rgba(0,224,255,0.7); animation: rgbshift 2.2s steps(12) infinite; }
  .crt-brand .cur { color: #00e0c6; animation: blink 0.7s steps(2) infinite; }
  .crt-prompt { color: #cfd3da; font-size: 0.8rem; letter-spacing: 0.32em;
    border: 1px solid rgba(255,255,255,0.25); padding: 9px 16px; border-radius: 4px; animation: blink 1.4s steps(2) infinite; }
  .crt-bar { position: absolute; left: 0; right: 0; height: 18%; z-index: 1; pointer-events: none;
    background: linear-gradient(180deg, transparent, rgba(255,255,255,0.07) 45%, rgba(255,255,255,0.12) 50%, transparent);
    animation: roll 5.5s linear infinite; }

  .warp { position: absolute; inset: 0; width: 100%; height: 100%; z-index: 4; opacity: 0; transition: opacity 0.25s ease; }
  .warp-text { position: absolute; inset: 0; z-index: 6; display: grid; place-items: center; pointer-events: none; }
  .warp-text span.t-old, .warp-text span.t-new { grid-area: 1 / 1; font-weight: 700; white-space: nowrap;
    letter-spacing: 0.04em; opacity: 0; }
  .t-old { font-size: clamp(1.4rem, 6vw, 3rem); color: #aeb6c2;
    text-shadow: 0 2px 18px rgba(0,0,0,0.9); }
  .t-new { font-size: clamp(1.6rem, 7vw, 3.6rem); color: #eef0f4;
    text-shadow: 0 0 22px rgba(0,0,0,0.85), 0 0 40px rgba(0,224,198,0.45); }
  .t-new .accent { color: #00e0c6; }
  .crt-flash { position: absolute; inset: 0; z-index: 7; background: #fff; opacity: 0; pointer-events: none; }

  @keyframes flicker { 0% { opacity: 0.97; } 100% { opacity: 1; } }
  @keyframes blink { 0%, 49% { opacity: 1; } 50%, 100% { opacity: 0.25; } }
  @keyframes roll { 0% { top: -20%; } 100% { top: 120%; } }
  @keyframes rgbshift {
    0%, 100% { text-shadow: 2px 0 rgba(255,0,80,0.7), -2px 0 rgba(0,224,255,0.7); }
    50% { text-shadow: -3px 0 rgba(255,0,80,0.7), 3px 0 rgba(0,224,255,0.7); }
  }

  /* CRT power-off collapse — grounded in Android's ElectronBeam.java:
     phase 1 = vertical squash to a line (~58%), phase 2 = horizontal snap to a dot
     + white flash & bloom (~42%). Sigmoid-ish easing; RGB fringe = chromatic aberration;
     P22 phosphor decays in ms, so the dot's afterglow is short. */
  .intro.off { pointer-events: none; }
  .intro.off .crt-screen { animation: crtSquash 0.62s cubic-bezier(0.7, 0, 0.3, 1) forwards; }
  @keyframes crtSquash {
    0%   { transform: scaleY(1) scaleX(1);      filter: brightness(1) saturate(1) contrast(1); }
    44%  { transform: scaleY(0.06) scaleX(1.04); filter: brightness(2.1) saturate(1.4) contrast(1.2); }
    56%  { transform: scaleY(0.004) scaleX(1.06); filter: brightness(2.8) saturate(1.6); opacity: 1; }
    62%  { opacity: 0; transform: scaleY(0.004) scaleX(1.06); }
    100% { opacity: 0; transform: scaleY(0) scaleX(1); }
  }

  /* the electron beam concentrating: bright full-width line -> dot, with bloom flash.
     box-shadow carries an R/cyan vertical fringe (cheap chromatic aberration). */
  .crt-line {
    position: absolute; left: 0; right: 0; top: 50%; height: 3px; z-index: 6;
    transform: translateY(-50%) scaleX(1) scaleY(1); transform-origin: center center;
    background: #fff; opacity: 0; pointer-events: none; border-radius: 2px;
  }
  .intro.off .crt-line { animation: beamLine 0.62s cubic-bezier(0.7, 0, 0.3, 1) forwards; }
  @keyframes beamLine {
    0%, 50% { opacity: 0; transform: translateY(-50%) scaleX(1) scaleY(0.5);
              box-shadow: 0 0 8px 1px rgba(255,255,255,0.5),
                          0 -2px 0 rgba(255,40,80,0.45), 0 2px 0 rgba(40,200,255,0.45); }
    56%     { opacity: 1; transform: translateY(-50%) scaleX(1) scaleY(1);
              box-shadow: 0 0 22px 3px rgba(255,255,255,0.85),
                          0 -3px 0 rgba(255,40,80,0.6), 0 3px 0 rgba(40,200,255,0.6); }
    70%     { opacity: 1; transform: translateY(-50%) scaleX(0.55) scaleY(1.1);
              box-shadow: 0 0 26px 4px rgba(255,255,255,0.9); }
    82%     { opacity: 0.5; transform: translateY(-50%) scaleX(0.18) scaleY(1.1);
              box-shadow: 0 0 20px 3px rgba(255,255,255,0.7); }
    100%    { opacity: 0; transform: translateY(-50%) scaleX(0.06) scaleY(0.8);
              box-shadow: 0 0 12px 2px rgba(255,255,255,0); }
  }

  /* the final beam dot: a small round element (uniform scale -> bloom isn't crushed)
     that flashes white-hot with a teal halo as the line vanishes, then fades fast. */
  .crt-dot {
    position: absolute; left: 50%; top: 50%; width: 6px; height: 6px; z-index: 6;
    border-radius: 50%; background: #fff; opacity: 0; pointer-events: none;
    transform: translate(-50%, -50%) scale(0.2);
  }
  .intro.off .crt-dot { animation: beamDot 0.62s cubic-bezier(0.7, 0, 0.3, 1) forwards; }
  @keyframes beamDot {
    0%, 68% { opacity: 0; transform: translate(-50%,-50%) scale(0.2);
              box-shadow: 0 0 0 0 rgba(255,255,255,0); }
    84%     { opacity: 1; transform: translate(-50%,-50%) scale(1.1);
              box-shadow: 0 0 55px 16px rgba(255,255,255,1), 0 0 150px 54px rgba(0,230,203,0.5); }
    100%    { opacity: 0; transform: translate(-50%,-50%) scale(0.5);
              box-shadow: 0 0 22px 4px rgba(255,255,255,0), 0 0 60px 10px rgba(0,230,203,0); }
  }

  /* hyperspace phase */
  .intro.warping .crt-screen { opacity: 0; transition: opacity 0.2s; }
  .intro.warping .warp { opacity: 1; }
  .intro.warping .t-old { animation: oldAway 0.85s cubic-bezier(0.7,0,0.84,0) forwards; }
  .intro.warping .t-new { animation: newIn 1.2s 0.84s cubic-bezier(0.16,1,0.3,1) forwards; }
  /* old solutions sucked into the vanishing point */
  @keyframes oldAway {
    0% { opacity: 0.9; transform: scale(1); filter: blur(0); }
    100% { opacity: 0; transform: scale(0.02); filter: blur(6px); }
  }
  /* newlifesolutions rushes out of the core toward the viewer */
  @keyframes newIn {
    0% { opacity: 0; transform: scale(0.04); filter: blur(2px); letter-spacing: 0.4em; }
    40% { opacity: 1; transform: scale(1); filter: blur(0); letter-spacing: 0.04em; }
    78% { opacity: 1; transform: scale(1.1); }
    100% { opacity: 0; transform: scale(3.4); filter: blur(5px); }
  }

  /* arrival flash */
  .intro.arrive .crt-flash { animation: flashBang 0.4s ease-out forwards; }
  @keyframes flashBang { 0% { opacity: 0; } 28% { opacity: 0.95; } 100% { opacity: 0; } }
</style>
