---
// CRT-TV intro overlay: animated static/interference. On click/tap/swipe the picture
// collapses like an old cathode-ray TV powering off → white flash "BAM" → reveals the site.
// Shows once per session. Skipped for prefers-reduced-motion. Safety auto-enter after 9s.
import type { Lang } from '../i18n/ui';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const prompt = lang === 'es' ? 'CLICK O DESLIZA PARA ENTRAR' : 'CLICK OR SWIPE TO ENTER';
const signal = lang === 'es' ? 'SEÑAL ENTRANTE' : 'INCOMING SIGNAL';
---
<div id="intro" class="intro" role="button" tabindex="0" aria-label={prompt}>
  <div class="crt-screen">
    <canvas id="crt-noise"></canvas>
    <div class="crt-content">
      <div class="crt-sig mono">▚ {signal}</div>
      <div class="crt-brand mono" data-text="newlife">newlife<span class="cur">_</span></div>
      <div class="crt-prompt mono">{prompt}</div>
    </div>
    <div class="crt-bar" aria-hidden="true"></div>
  </div>
  <div class="crt-flash" aria-hidden="true"></div>
</div>

<script>
  const intro = document.getElementById('intro');
  if (intro) {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const seen = sessionStorage.getItem('nl_intro_seen');
    if (reduce || seen) {
      intro.remove();
    } else {
      document.documentElement.style.overflow = 'hidden';
      const cv = document.getElementById('crt-noise') as HTMLCanvasElement;
      const ctx = cv.getContext('2d')!;
      cv.width = 240; cv.height = 135;
      const drawNoise = () => {
        const img = ctx.createImageData(cv.width, cv.height);
        const d = img.data;
        for (let i = 0; i < d.length; i += 4) {
          const v = (Math.random() * 255) | 0;
          d[i] = d[i + 1] = d[i + 2] = v; d[i + 3] = 255;
        }
        ctx.putImageData(img, 0, 0);
      };
      const noiseId = window.setInterval(drawNoise, 38);
      drawNoise();

      let entered = false;
      const enter = () => {
        if (entered) return;
        entered = true;
        window.clearInterval(noiseId);
        sessionStorage.setItem('nl_intro_seen', '1');
        intro.classList.add('off');
        window.setTimeout(() => {
          document.documentElement.style.overflow = '';
          intro.remove();
          document.dispatchEvent(new Event('intro:done'));
        }, 660);
      };

      intro.addEventListener('pointerdown', enter);
      intro.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); enter(); }
      });
      let ty = 0;
      intro.addEventListener('touchstart', (e) => { ty = e.touches[0].clientY; }, { passive: true });
      intro.addEventListener('touchmove', (e) => {
        if (Math.abs(e.touches[0].clientY - ty) > 26) enter();
      }, { passive: true });
      intro.focus();
      window.setTimeout(enter, 9000); // safety auto-enter
    }
  }
</script>

<style>
  .intro {
    position: fixed; inset: 0; z-index: 9999;
    background: #050507; cursor: pointer; overflow: hidden;
    display: grid; place-items: center;
  }
  .crt-screen {
    position: absolute; inset: 0; transform-origin: center center;
    animation: flicker 0.13s steps(2) infinite;
  }
  #crt-noise {
    position: absolute; inset: 0; width: 100%; height: 100%;
    image-rendering: pixelated; opacity: 0.28;
  }
  /* scanlines */
  .crt-screen::after {
    content: ''; position: absolute; inset: 0; pointer-events: none;
    background: repeating-linear-gradient(0deg, rgba(0,0,0,0) 0, rgba(0,0,0,0) 2px, rgba(0,0,0,0.45) 3px);
    mix-blend-mode: multiply;
  }
  /* vignette / tube curvature feel */
  .crt-screen::before {
    content: ''; position: absolute; inset: 0; pointer-events: none; z-index: 3;
    background: radial-gradient(ellipse 100% 100% at 50% 50%, transparent 55%, rgba(0,0,0,0.85) 100%);
  }
  .crt-content {
    position: absolute; inset: 0; z-index: 2; display: flex; flex-direction: column;
    align-items: center; justify-content: center; gap: 18px; text-align: center; padding: 24px;
  }
  .crt-sig { color: #00e0c6; font-size: 0.78rem; letter-spacing: 0.4em; opacity: 0.7;
    animation: blink 1.1s steps(2) infinite; }
  .crt-brand {
    font-size: clamp(2.6rem, 11vw, 6rem); font-weight: 700; letter-spacing: -0.02em; color: #eef0f4;
    text-shadow: 2px 0 rgba(255,0,80,0.7), -2px 0 rgba(0,224,255,0.7);
    animation: rgbshift 2.2s steps(12) infinite;
  }
  .crt-brand .cur { color: #00e0c6; animation: blink 0.7s steps(2) infinite; }
  .crt-prompt { color: #cfd3da; font-size: 0.8rem; letter-spacing: 0.32em;
    border: 1px solid rgba(255,255,255,0.25); padding: 9px 16px; border-radius: 4px;
    animation: blink 1.4s steps(2) infinite; }
  /* rolling interference bar */
  .crt-bar {
    position: absolute; left: 0; right: 0; height: 18%; z-index: 1; pointer-events: none;
    background: linear-gradient(180deg, transparent, rgba(255,255,255,0.07) 45%, rgba(255,255,255,0.12) 50%, transparent);
    animation: roll 5.5s linear infinite;
  }
  .crt-flash { position: absolute; inset: 0; z-index: 5; background: #fff; opacity: 0; pointer-events: none; }

  @keyframes flicker { 0% { opacity: 0.97; } 100% { opacity: 1; } }
  @keyframes blink { 0%, 49% { opacity: 1; } 50%, 100% { opacity: 0.25; } }
  @keyframes roll { 0% { top: -20%; } 100% { top: 120%; } }
  @keyframes rgbshift {
    0%, 100% { text-shadow: 2px 0 rgba(255,0,80,0.7), -2px 0 rgba(0,224,255,0.7); }
    50% { text-shadow: -3px 0 rgba(255,0,80,0.7), 3px 0 rgba(0,224,255,0.7); }
  }

  /* --- CRT power-off collapse on enter --- */
  .intro.off { pointer-events: none; }
  .intro.off .crt-screen { animation: crtCollapse 0.55s cubic-bezier(0.6, 0, 0.4, 1) forwards; }
  .intro.off .crt-flash { animation: flashBang 0.62s ease-out forwards; }

  @keyframes crtCollapse {
    0%   { transform: scaleX(1) scaleY(1);     filter: brightness(1) contrast(1); }
    45%  { transform: scaleX(1) scaleY(0.018);  filter: brightness(2.6) contrast(1.5); }
    60%  { transform: scaleX(0.7) scaleY(0.018); filter: brightness(4); }
    78%  { transform: scaleX(0) scaleY(0.018);  filter: brightness(7); }
    79%  { transform: scaleX(0) scaleY(0); }
    100% { transform: scaleX(0) scaleY(0); opacity: 0; }
  }
  @keyframes flashBang {
    0%, 52% { opacity: 0; }
    66% { opacity: 0.95; }
    100% { opacity: 0; }
  }
</style>
