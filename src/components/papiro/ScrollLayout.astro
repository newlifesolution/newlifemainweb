---
/**
 * ScrollLayout — Wraps content in the papyrus scroll aesthetic.
 * Use this as the main content wrapper for any page that should
 * look like a grimoire page.
 */
interface Props {
  maxWidth?: string;
}

const { maxWidth = '800px' } = Astro.props;
---

<div class="scroll-container" style={`max-width: ${maxWidth}`}>
  <div class="scroll-roll">
    <div class="knob left"></div>
    <div class="knob right"></div>
  </div>

  <div class="papyrus">
    <slot />
  </div>

  <div class="scroll-roll bottom">
    <div class="knob left"></div>
    <div class="knob right"></div>
  </div>
</div>

<style>
  .scroll-container {
    width: 100%;
    margin: 0 auto;
  }

  .scroll-roll {
    height: 38px;
    background: linear-gradient(180deg,
      #5a4420 0%, #7a6235 15%, #8b7245 30%, #a08855 50%,
      #8b7245 70%, #6b5230 85%, #4a3820 100%);
    border-radius: 5px;
    position: relative;
    z-index: 2;
    box-shadow: 0 4px 16px rgba(0,0,0,0.6), inset 0 1px 0 rgba(255,235,180,0.15);
  }

  .knob {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 20px;
    height: 32px;
    background: radial-gradient(ellipse at center, #d4a050, #8b6914, #5a4012);
    border-radius: 4px;
    box-shadow: 2px 0 8px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,235,180,0.3);
  }

  .knob.left { left: -6px; }
  .knob.right { right: -6px; }

  .papyrus {
    background: var(--g-bg-papyrus);
    background-image:
      url("data:image/svg+xml,%3Csvg width='200' height='200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence baseFrequency='0.65' numOctaves='4' stitchTiles='stitch'/%3E%3CfeColorMatrix type='saturate' values='0'/%3E%3C/filter%3E%3Crect width='200' height='200' filter='url(%23n)' opacity='0.08'/%3E%3C/svg%3E");
    padding: 3rem 2.5rem;
    position: relative;
    box-shadow:
      inset 0 0 80px rgba(139,108,66,0.3),
      inset 0 0 160px rgba(139,108,66,0.1),
      0 0 40px rgba(0,0,0,0.6);
    border-left: 3px solid var(--g-burn-edge);
    border-right: 3px solid var(--g-burn-edge);
  }

  @media (max-width: 600px) {
    .papyrus { padding: 2rem 1.2rem; }
  }
</style>
