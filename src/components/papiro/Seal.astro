---
/**
 * Seal — Circular wax seal decoration.
 */
interface Props {
  text?: string;
  size?: number;
}

const { text = 'IF', size = 50 } = Astro.props;
---

<div class="seal" style={`width: ${size}px; height: ${size}px`}>
  <span class="seal-text" style={`font-size: ${size * 0.36}px`}>{text}</span>
</div>

<style>
  .seal {
    display: inline-block;
    border: 2px solid var(--g-seal-red);
    border-radius: 50%;
    position: relative;
    opacity: 0.6;
    animation: seal-pulse 4s ease-in-out infinite;
  }

  .seal-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: var(--g-font-display);
    font-weight: 700;
    color: var(--g-seal-red);
  }

  @keyframes seal-pulse {
    0%, 100% { box-shadow: 0 0 0 rgba(160,32,32,0); }
    50% { box-shadow: 0 0 20px rgba(160,32,32,0.2); }
  }
</style>
