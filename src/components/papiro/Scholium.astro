---
/**
 * Scholium — Collapsible detail block for supplementary info.
 * Styled as a margin annotation on old manuscripts.
 */
interface Props {
  title: string;
  open?: boolean;
}

const { title, open = false } = Astro.props;
---

<details class="scholium" open={open}>
  <summary>{title}</summary>
  <div class="scholium-body">
    <slot />
  </div>
</details>

<style>
  .scholium {
    margin: 0.8rem 0;
    background: rgba(180,159,106,0.12);
    border-left: 3px solid var(--g-burn-edge);
    border-radius: 0 4px 4px 0;
  }

  summary {
    font-family: var(--g-font-body);
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--g-ink-primary);
    cursor: pointer;
    padding: 0.5rem 0.8rem;
    list-style: none;
    position: relative;
    user-select: none;
  }

  summary::before {
    content: '\25B8';
    position: absolute;
    left: -14px;
    color: var(--g-ink-gold);
    font-size: 0.75rem;
    transition: transform 0.2s;
  }

  .scholium[open] summary::before {
    transform: rotate(90deg);
  }

  summary::-webkit-details-marker { display: none; }

  .scholium-body {
    padding: 0.4rem 0.8rem 0.8rem;
    font-size: 0.88rem;
    color: var(--g-ink-secondary);
    line-height: 1.7;
    border-top: 1px solid rgba(184,159,106,0.3);
  }

  .scholium-body :global(p) {
    margin-bottom: 0.5rem;
  }
</style>
