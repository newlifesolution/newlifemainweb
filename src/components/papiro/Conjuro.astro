---
/**
 * Conjuro — Dark block for formulas, summaries, or key concepts.
 * Used inside MDX content or Astro pages.
 */
interface Props {
  symbol?: string;
  title: string;
  seal?: string;
}

const { symbol = '🜔', title, seal } = Astro.props;
---

<div class="conjuro">
  <div class="conjuro-header">
    <span class="conjuro-symbol">{symbol}</span>
    <span class="conjuro-title">{title}</span>
  </div>
  <div class="conjuro-body">
    <slot />
  </div>
  {seal && (
    <div class="conjuro-seal">{seal}</div>
  )}
</div>

<style>
  .conjuro {
    max-width: 640px;
    margin: 1.5rem auto;
    background: var(--g-bg-conjuro);
    border: 1.5px solid var(--g-conjuro-border);
    border-radius: 4px;
    padding: 1.2rem 1.4rem;
    position: relative;
    box-shadow:
      0 0 30px rgba(196,160,80,0.1),
      inset 0 0 40px rgba(0,0,0,0.4);
  }

  .conjuro::before {
    content: '';
    position: absolute;
    top: 4px; left: 4px; right: 4px; bottom: 4px;
    border: 1px dashed rgba(196,160,80,0.2);
    border-radius: 2px;
    pointer-events: none;
  }

  .conjuro-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 0.6rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(196,160,80,0.2);
  }

  .conjuro-symbol {
    font-size: 1.2rem;
    color: var(--g-conjuro-border);
    line-height: 1;
  }

  .conjuro-title {
    font-family: var(--g-font-display);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--g-conjuro-border);
    letter-spacing: 3px;
    text-transform: uppercase;
  }

  .conjuro-body {
    font-family: var(--g-font-mono);
    font-size: 0.8rem;
    line-height: 1.8;
    color: var(--g-conjuro-text);
    white-space: pre-line;
  }

  .conjuro-body :global(strong) {
    color: var(--g-conjuro-border);
    font-weight: 600;
  }

  .conjuro-seal {
    margin-top: 0.8rem;
    padding-top: 0.6rem;
    border-top: 1px solid rgba(196,160,80,0.2);
    font-family: var(--g-font-body);
    font-style: italic;
    font-size: 0.82rem;
    color: rgba(196,160,80,0.6);
  }
</style>
