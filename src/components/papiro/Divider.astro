---
/**
 * Divider — Golden gradient horizontal rule.
 */
interface Props {
  symbol?: boolean;
}

const { symbol = false } = Astro.props;
---

{symbol ? (
  <div class="pentacle-break">☿ ⟐ ♃ ⟡ ♄</div>
) : (
  <hr class="divider" />
)}

<style>
  .divider {
    border: none;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--g-ink-gold), var(--g-ink-secondary), var(--g-ink-gold), transparent);
    margin: 2rem 0;
    opacity: 0.4;
  }

  .pentacle-break {
    text-align: center;
    margin: 2rem 0;
    color: var(--g-ink-gold);
    opacity: 0.3;
    font-size: 1.1rem;
    letter-spacing: 12px;
    font-family: var(--g-font-symbols);
  }
</style>
