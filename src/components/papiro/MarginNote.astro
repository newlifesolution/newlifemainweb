---
/**
 * MarginNote — Side annotation that floats right on desktop,
 * becomes inline callout on mobile.
 */
---

<aside class="margin-note">
  <slot />
</aside>

<style>
  .margin-note {
    display: block;
    float: right;
    clear: right;
    width: 150px;
    margin: 0 -170px 0.5rem 1rem;
    font-size: 0.72rem;
    font-style: italic;
    color: var(--g-ink-gold);
    line-height: 1.4;
    border-left: 1px solid var(--g-ink-gold);
    padding-left: 8px;
    font-family: var(--g-font-body);
  }

  @media (max-width: 900px) {
    .margin-note {
      float: none;
      width: 100%;
      margin: 0.5rem 0;
      padding: 0.3rem 0.8rem;
      border-left: 2px solid var(--g-ink-gold);
      background: rgba(139,105,20,0.05);
      border-radius: 0 3px 3px 0;
    }
  }
</style>
