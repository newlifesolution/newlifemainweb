---
/**
 * Glosario — Recursive collapsible glossary tree.
 * Each entry is a <details>; children render the component again,
 * so a parent term can contain arbitrarily nested sub-terms.
 */
import { render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entries: CollectionEntry<'glosario'>[];
  all: CollectionEntry<'glosario'>[];
  depth?: number;
}

const { entries, all, depth = 0 } = Astro.props;

const sorted = [...entries].sort((a, b) => {
  const oa = a.data.order ?? 99;
  const ob = b.data.order ?? 99;
  if (oa !== ob) return oa - ob;
  return a.data.term.localeCompare(b.data.term, 'es');
});

const childrenOf = (slug: string) =>
  all.filter(e => e.data.parent === slug);

const renderedBodies = await Promise.all(
  sorted.map(async (e) => {
    const { Content } = await render(e);
    return { entry: e, Content };
  })
);
---

<ul class={`glosario glosario-depth-${depth}`}>
  {renderedBodies.map(({ entry, Content }) => {
    const kids = childrenOf(entry.id);
    const aliases = entry.data.aliases ?? [];
    const related = entry.data.related ?? [];
    return (
      <li class="glosario-item" id={`g-${entry.id}`}>
        <details class="g-details">
          <summary class="g-summary">
            <span class="g-term">{entry.data.term}</span>
            {aliases.length > 0 && (
              <span class="g-aliases">— {aliases.join(' · ')}</span>
            )}
            {kids.length > 0 && (
              <span class="g-count">({kids.length})</span>
            )}
          </summary>

          <div class="g-body">
            <Content />

            {related.length > 0 && (
              <div class="g-related">
                <span class="g-related-label">Véase también:</span>
                {related.map((slug, i) => (
                  <>
                    {i > 0 && <span class="g-sep">·</span>}
                    <a href={`#g-${slug}`} class="g-related-link">{slug.replace(/-/g, ' ')}</a>
                  </>
                ))}
              </div>
            )}

            {entry.data.source && (
              <div class="g-source">Fuente: {entry.data.source}</div>
            )}

            {kids.length > 0 && (
              <Astro.self entries={kids} all={all} depth={depth + 1} />
            )}
          </div>
        </details>
      </li>
    );
  })}
</ul>

<style>
  .glosario {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .glosario-depth-0 > .glosario-item {
    margin-bottom: 0.5rem;
  }

  .glosario-item {
    border-left: 2px solid var(--g-pentacle-line);
    margin: 0.35rem 0;
  }

  .glosario-depth-0 > .glosario-item {
    border-left: 3px solid var(--g-burn-edge);
    background: rgba(180,159,106,0.08);
    border-radius: 0 4px 4px 0;
  }

  .g-details {
    /* no extra padding — summary handles it */
  }

  .g-summary {
    cursor: pointer;
    list-style: none;
    user-select: none;
    padding: 0.45rem 0.8rem 0.45rem 1.1rem;
    position: relative;
    font-family: var(--g-font-body);
    font-size: 0.95rem;
    color: var(--g-ink-primary);
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
    flex-wrap: wrap;
    transition: background 0.15s;
  }

  .g-summary:hover {
    background: rgba(139,108,66,0.07);
  }

  .g-summary::before {
    content: '\25B8';
    position: absolute;
    left: 0.35rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--g-ink-gold);
    font-size: 0.7rem;
    transition: transform 0.2s;
  }

  .g-details[open] > .g-summary::before {
    transform: translateY(-50%) rotate(90deg);
  }

  .g-summary::-webkit-details-marker { display: none; }

  .g-term {
    font-weight: 600;
    color: var(--g-ink-primary);
  }

  .glosario-depth-0 .g-term {
    font-family: var(--g-font-display);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--g-ink-gold);
  }

  .g-aliases {
    font-style: italic;
    font-size: 0.82rem;
    color: var(--g-ink-secondary);
    opacity: 0.75;
  }

  .g-count {
    font-family: var(--g-font-mono);
    font-size: 0.6rem;
    color: var(--g-ink-gold);
    background: rgba(196,160,80,0.1);
    padding: 1px 6px;
    border-radius: 8px;
    letter-spacing: 0.5px;
  }

  .g-body {
    padding: 0.3rem 0.9rem 0.7rem 1.1rem;
    border-top: 1px dashed rgba(196,160,80,0.25);
    font-size: 0.9rem;
    color: var(--g-ink-secondary);
    line-height: 1.7;
  }

  .g-body :global(p) {
    margin: 0.25rem 0 0.4rem;
  }

  .g-body :global(strong) {
    color: var(--g-ink-primary);
    font-weight: 600;
  }

  .g-body :global(code) {
    font-family: var(--g-font-mono);
    font-size: 0.78rem;
    background: rgba(42,31,20,0.08);
    padding: 1px 4px;
    border-radius: 2px;
  }

  .g-body :global(ul),
  .g-body :global(ol) {
    margin: 0.3rem 0 0.5rem 1.2rem;
  }

  .g-body :global(li) {
    margin-bottom: 0.15rem;
  }

  .g-related {
    margin-top: 0.45rem;
    padding-top: 0.35rem;
    border-top: 1px solid rgba(196,160,80,0.12);
    font-size: 0.72rem;
    color: var(--g-ink-secondary);
  }

  .g-related-label {
    font-family: var(--g-font-display);
    font-size: 0.6rem;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--g-ink-gold);
    margin-right: 0.4rem;
    opacity: 0.7;
  }

  .g-related-link {
    color: var(--g-ink-gold);
    text-decoration: none;
    border-bottom: 1px dotted rgba(139,105,20,0.4);
  }

  .g-related-link:hover {
    border-bottom-color: var(--g-ink-gold);
    opacity: 1;
  }

  .g-sep {
    color: var(--g-ink-gold);
    opacity: 0.4;
    margin: 0 0.3rem;
  }

  .g-source {
    margin-top: 0.4rem;
    font-family: var(--g-font-mono);
    font-size: 0.65rem;
    color: var(--g-ink-secondary);
    opacity: 0.6;
  }
</style>
